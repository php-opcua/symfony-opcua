{
    "name": "php-opcua/symfony-opcua",
    "description": "Symfony integration for OPC UA client with optional session manager support",
    "type": "symfony-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Gianfrancesco Aurecchia",
            "email": "gianfri.aur@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "php-opcua/opcua-client": "^4.1.1",
        "php-opcua/opcua-session-manager": "^4.1",
        "psr/event-dispatcher": "^1.0",
        "symfony/framework-bundle": "^6.4|^7.0|^8.0",
        "symfony/console": "^6.4|^7.0|^8.0",
        "symfony/dependency-injection": "^6.4|^7.0|^8.0",
        "symfony/config": "^6.4|^7.0|^8.0",
        "symfony/cache": "^6.4|^7.0|^8.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "mockery/mockery": "^1.6",
        "symfony/yaml": "^6.4|^7.0|^8.0",
        "symfony/event-dispatcher": "^6.4|^7.0|^8.0"
    },
    "autoload": {
        "psr-4": {
            "PhpOpcua\\SymfonyOpcua\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpOpcua\\SymfonyOpcua\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
